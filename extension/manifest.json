{
  "manifest_version": 3,
  "name": "MCP Data Explorer",
  "version": "1.0",
  "description": "Search and fetch data using MCP and Gemini.",
  "permissions": ["activeTab", "sidePanel"],
  "action": {
    "default_title": "Open MCP Explorer"
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "host_permissions": ["http://localhost:8000/*", "http://127.0.0.1:8000/*"]
}
